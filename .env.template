# KASIO — Environment Variables
# Copy isi file ini ke ~/.hermes/profiles/kasio/.env (atau ke .env profile Hermes kamu)
# Isi nilai yang kosong. Required = WAJIB. Optional = boleh skip kalau tidak pakai fitur tsb.

# === Required ===

# Notion integration API key. Buat di https://www.notion.so/my-integrations
# Pastikan integration sudah di-invite ke kedua DB (transactions + accounts).
NOTION_API_KEY=

# Notion Data Source ID untuk transactions DB.
# Cara: Buka DB di Notion → klik "..." → "Connections" → invite integration.
# Copy dari URL setelah invite (lihat README untuk detail).
KASIO_TRANSACTIONS_DS_ID=

# Notion Data Source ID untuk accounts DB.
KASIO_ACCOUNTS_DS_ID=

# === Optional ===

# MiniMax M3 API key untuk vision reading struk/screenshot bank.
# Skip kalau tidak pakai fitur vision (foto struk → auto-extract).
# Get di https://api.minimax.io/
MINIMAX_API_KEY=

# === Optional: Auto-refresh Notion summary page ===
# Kalau di-set, plugin auto-update Notion page ringkasan tiap kali ada
# transaksi baru (save/update/archive). Page harus sudah di-share ke
# integration sama dengan NOTION_API_KEY di atas.
# Default kosong = fitur opt-out, plugin jalan seperti biasa.
KASIO_NOTION_SUMMARY_PAGE_ID=
